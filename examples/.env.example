# .env.example - Copy this to the repo root as .env and customize
# This file shows all available configuration options

# PROJECT_DIR - The directory you want OpenCode to work on
# Default: Current directory when running opencode-dockerized.sh
PROJECT_DIR=/home/youruser/projects/myproject

# HOST_UID - Your user ID (automatically detected by scripts)
# Default: Output of $(id -u)
HOST_UID=1000

# HOST_GID - Your group ID (automatically detected by scripts)
# Default: Output of $(id -g)
HOST_GID=1000

# TERM - Terminal type for proper color support
# Default: xterm-256color
TERM=xterm-256color
